# ─── GitHub OAuth Configuration ───────────────────────────────────
# Create a GitHub OAuth App: https://github.com/settings/developers
EXPO_PUBLIC_GITHUB_CLIENT_ID=your_github_oauth_app_client_id
GITHUB_CLIENT_SECRET=your_github_oauth_app_client_secret

# Use 'repo' scope (not 'public_repo') to enable closing issues
EXPO_PUBLIC_GITHUB_SCOPE=repo

# ─── API Server Configuration ─────────────────────────────────────
# For local development, point to the Express server (port 3000)
# In production, this can be omitted (defaults to same origin)
EXPO_PUBLIC_API_URL=http://localhost:3000

# ─── AI Features (Optional) ───────────────────────────────────────
# For GitHub Copilot AI summaries, provide ONE of these tokens:
# - GH_TOKEN: GitHub Personal Access Token with Copilot access (recommended)
# - COPILOT_PAT: Alternative token name for Copilot access
# Leave blank to disable AI features (app still works without them)
GH_TOKEN=your_github_token_with_copilot_access
# COPILOT_PAT=your_copilot_pat_alternative

# ─── Session Storage (Optional) ───────────────────────────────────
# Azure Cosmos DB for persistent sessions (optional, falls back to in-memory)
# Without Cosmos DB, sessions are lost on server restart
COSMOS_ENDPOINT=https://your-account.documents.azure.com:443/
COSMOS_KEY=your_cosmos_primary_key
COSMOS_DATABASE=issuecrush
COSMOS_CONTAINER=sessions
